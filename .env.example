# ========== 后端 Render 环境变量 ==========
# DeepSeek API
DEEPSEEK_API_KEY=你的密钥

# JWT（生产环境请改成随机长字符串）
JWT_SECRET_KEY=请换成随机密钥

# 云端 MySQL（PlanetScale / Render MySQL 连接串）
DATABASE_URL=mysql://用户名:密码@主机:3306/数据库名
MYSQL_SSL=true

# 本地开发可改用分项配置：
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=123456
# MYSQL_DATABASE=ai_chat

# CORS：填 Vercel 前端地址，多个用逗号分隔
ALLOWED_ORIGINS=https://你的项目.vercel.app,http://localhost:5173

# Render 持久化磁盘路径（挂载 /data 后使用）
CHROMA_PATH=/data/chroma_db
UPLOAD_DIR=/data/uploads

# 本地开发可省略，默认 ./chroma_db 和 uploads
