# DeepSeek API（必填）
DEEPSEEK_API_KEY=你的密钥

# JWT 签名密钥（本地可保持默认，生产环境请改成随机字符串）
JWT_SECRET_KEY=ai-chat-local-dev-secret
APP_ENV=local

# 本地默认 SQLite，无需 MySQL
USE_SQLITE=true
SQLITE_PATH=chat.db

# 可选：MySQL 配置（USE_SQLITE=false 时使用）
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=123456
# MYSQL_DATABASE=ai_chat

# 前端开发地址（CORS）
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# 上传 / 聊天限制
MAX_UPLOAD_MB=20
CHAT_HISTORY_LIMIT=20
LLM_TIMEOUT_SECONDS=60

# 可选：本地数据目录
# UPLOAD_DIR=uploads
# CHROMA_PATH=chroma_db
